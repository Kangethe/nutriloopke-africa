# ─────────────────────────────────────────────────────────────────────────────
# NutriLoop Africa — Environment Variables
# Copy this file to .env.local and fill in all values before running locally.
# Never commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────────────────
# Project URL from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# anon/public key — safe to expose in browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# service_role key — NEVER expose in browser, server-side API routes only
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Resend (Email Delivery) ───────────────────────────────────────────────────
# Get from: resend.com → API Keys
# Must verify the sending domain: hello@nutriloopAfrica.com
RESEND_API_KEY=re_your_key_here

# The verified sender email address
RESEND_FROM_EMAIL=hello@nutriloopAfrica.com

# Founders' notification email (internal — not shown publicly)
FOUNDER_NOTIFICATION_EMAIL=founders@nutriloopAfrica.com

# ── Sanity CMS ────────────────────────────────────────────────────────────────
# Project ID from: sanity.io/manage → your project
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id

# Dataset: "production" for live, "development" for testing
NEXT_PUBLIC_SANITY_DATASET=production

# API version — use today's date when setting up
NEXT_PUBLIC_SANITY_API_VERSION=2024-05-11

# Read-only API token for SSR queries (not needed for public data)
SANITY_API_READ_TOKEN=sk_your_read_token_here

# ── NextAuth (Admin Dashboard) ────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-32-char-secret-here

# Your production URL (no trailing slash)
NEXTAUTH_URL=https://nutriloopAfrica.com

# ── Mapbox (Maps) ─────────────────────────────────────────────────────────────
# Get from: account.mapbox.com → Access Tokens
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here

# ── Analytics ────────────────────────────────────────────────────────────────
# Google Analytics 4 Measurement ID
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# Microsoft Clarity Project ID
NEXT_PUBLIC_CLARITY_ID=your_clarity_id

# ── Admin Dashboard ──────────────────────────────────────────────────────────
# Email address allowed to log into /admin
ADMIN_EMAIL=founders@nutriloopAfrica.com

# Admin password — use a strong random string (min 16 chars)
# Generate with: openssl rand -hex 24
ADMIN_PASSWORD=change-this-to-a-strong-random-password

# ── Optional: Google Site Verification ──────────────────────────────────────
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-google-verification-code
